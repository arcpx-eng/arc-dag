# AWS Bedrock — node.type: LLM
#
# Setup:
#   cp .env.bedrock.template .env.bedrock
#   Fill in BEDROCK_API_KEY
#
# Never commit .env.bedrock — it is gitignored.
# Loaded automatically by run-with-llm.mjs, run-local.mjs (see examples/lib/load-project-env.mjs)

BEDROCK_API_KEY=

BEDROCK_REGION=us-east-1

BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6

# Optional: maps to Python get_service_key(userId, "bedrock") when you add per-user keys
# BEDROCK_USER_ID=

# Request timeout (ms)
# BEDROCK_TIMEOUT_MS=120000
