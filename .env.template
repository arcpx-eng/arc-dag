# LLM endpoint configuration for arc-dag
#
# Setup:
#   cp .env.template .env
#   Fill in LLM_API_KEY (and adjust BASE / MODEL if needed)
#
# Never commit .env — it is gitignored.
# Used by: npm run run:llm, examples/run-with-llm.mjs, examples/run-local.mjs
#
# Bedrock (node.type LLM): use a separate file —
#   cp .env.bedrock.template .env.bedrock

# --- Required ---
# OpenAI-compatible API root (include /v1)
LLM_API_BASE=https://api.openai.com/v1

# API key or bearer token
LLM_API_KEY=

# Default model when not set in global-settings.json
LLM_MODEL=gpt-4o

# Optional: User-Agent for webpage / web-scraper nodes (examples/run:web-scraper)
# WEB_SCRAPER_USER_AGENT=MyApp/1.0

# --- AWS Bedrock: use .env.bedrock (see .env.bedrock.template) ---

# --- Alternatives (uncomment one block, comment OpenAI above) ---

# Ollama (local)
# LLM_API_BASE=http://localhost:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=llama3.2

# LM Studio (local)
# LLM_API_BASE=http://localhost:1234/v1
# LLM_API_KEY=lm-studio
# LLM_MODEL=local-model

# OpenRouter
# LLM_API_BASE=https://openrouter.ai/api/v1
# LLM_API_KEY=
# LLM_MODEL=openai/gpt-4o
